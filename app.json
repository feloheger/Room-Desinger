{
  "expo": {
    "name": "MFD",
    "slug": "womensaver",
    "owner": "womensavers-team",
    "scheme": "mfd",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.womensaversteam.mfd"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "package": "com.womensaversteam.mfd",
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ]
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Wir benötigen Zugriff auf deine Kamera.",
          "microphonePermission": false,
          "recordAudioAndroid": false
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Wir benötigen Zugriff auf deine Fotos."
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Wir speichern dein generiertes Konzept.",
          "savePhotosPermission": "Wir speichern dein generiertes Konzept.",
          "isAccessMediaLocationEnabled": false
        }
      ]
    ],
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "488656bf-9be3-4f54-b1c2-d7f4ca451af2"
      }
    }
  }
}
